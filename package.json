{
  "name": "@Ouilliam-21/database",
  "version": "1.0.0",
  "description": "Database for Ouilliam",
  "author": "MichelProgram",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Ouilliam-21/database.git"
  },
  "type": "module",
  "private": false,
  "main": "./dist/schema.js",
  "types": "./dist/schema.d.ts",
  "exports": {
    ".": {
      "types": "./dist/schema.d.ts",
      "import": "./dist/schema.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "generate:schema": "bun scripts/generate-mermaid.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@types/bun": "latest",
    "@types/pg": "^8.16.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "drizzle-kit": "^0.31.8",
    "eslint": "^9.0.0",
    "eslint-plugin-drizzle": "^0.2.3",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "^0.7.0",
    "pg": "^8.16.3",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}
